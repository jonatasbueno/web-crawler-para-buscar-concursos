{
  "name": "crawler-concursos",
  "version": "1.0.0",
  "description": "Crawler modular para busca de concursos públicos na região de Capivari-SP",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/cli.js",
    "run-once": "node src/cli.js",
