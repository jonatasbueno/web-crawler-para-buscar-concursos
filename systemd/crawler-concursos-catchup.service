[Unit]
Description=Crawler Concursos - catch-up ao ligar o PC
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=__PROJECT_DIR__
EnvironmentFile=-__PROJECT_DIR__/.env
ExecStart=/usr/bin/node src/cli.js --catch-up
StandardOutput=append:__PROJECT_DIR__/data/cron.log
StandardError=append:__PROJECT_DIR__/data/cron.log

[Install]
WantedBy=default.target
